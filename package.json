{
  "name": "obfuscator",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "bin": {
    "sukared": "./cli.js"
  },
  "scripts": {
    "test": "node test_obfuscator.js",
    "test:vm": "node test_vm.js",
    "test:vm:selected": "node test_vm.js",
    "test:vm:aggressive": "node test_vm.js",
    "test:runtime": "node test_obfuscator.js",
    "test:adversarial": "node test_adversarial.js",
    "test:hell-prep": "node test_hell_preparation.js",
    "test:hell": "node test_hell.js",
    "test:hell-adversarial": "node test_hell_adversarial.js",
    "test:pc-remap": "node test_pc_remap.js",
    "test:runtime-harness": "node test_runtime_harness.js",
    "test:stress:100": "node tests/stress_runner.js --functions 100 --seed stress-100",
    "test:stress:250": "node tests/stress_runner.js --functions 250 --seed stress-250",
    "test:stress:500": "node tests/stress_runner.js --functions 500 --seed stress-500",
    "test:stress:1000": "node tests/stress_runner.js --functions 1000 --seed stress-1000",
    "test:stress:2000": "node tests/stress_runner.js --functions 2000 --seed stress-2000",
    "test:fuzz": "node tests/vm_fuzzer.js --count 500",
    "test:mega": "node test_mega.js",
    "test:mega-profiles": "node test_mega_profiles.js",
    "test:service": "node test_service_hardening.js",
    "test:semantic": "node test_semantic_audit.js",
    "test:scale": "node test_scale_matrix.js",
    "test:scale:smoke": "node test_scale_matrix.js --quick",
    "test:beta:smoke": "npm run test:regressions && npm run test:runtime-harness && npm run test:semantic && npm run test:mega-profiles && npm run test:service && npm run test:scale:smoke",
    "test:public-beta": "node test_public_beta_matrix.js",
    "test:beta:acceptance": "npm run test:regressions && npm run test:runtime-harness && npm run test:semantic && npm run test:mega && npm run test:mega-profiles && npm run test:service && npm run test:public-beta && npm run test:fuzz && npm run test:scale",
    "test:hell:full": "npm run test:regressions && npm run test:pc-remap && npm run test:stress:1000 && npm run test:fuzz && npm run test:mega && npm run test:hell-adversarial && npm run benchmark:hell",
    "test:regressions": "node test_obfuscator.js && node test_vm.js && node test_adversarial.js && node test_hell_preparation.js",
    "benchmark:vm": "node --expose-gc benchmark_vm.js",
    "benchmark:hell": "node --expose-gc benchmark_hell.js",
    "benchmark:large": "node --expose-gc benchmark_large_runtime.js",
    "start": "node server.js",
    "dev": "node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@roblox-ts/luau-ast": "^2.0.1",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "astring": "^1.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "luaparse": "^0.3.1",
    "luau-web": "^1.4.0"
  }
}
